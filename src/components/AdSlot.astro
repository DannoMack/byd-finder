---
interface Props {
  slot?: string;
  format?: 'horizontal' | 'rectangle' | 'vertical';
  label?: boolean;
}
const { slot = 'placeholder', format = 'horizontal', label = true } = Astro.props;

// AdSense client ID — set via env var once AdSense is approved.
// Falls back to nothing (renders placeholder) until wired up.
const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT || '';

const sizes = {
  horizontal: 'min-h-[90px] md:min-h-[120px]',
  rectangle: 'min-h-[250px]',
  vertical: 'min-h-[600px]',
};
---
<aside class:list={['w-full flex flex-col items-center justify-center my-8 rounded-lg border border-dashed border-[var(--color-border)] bg-[var(--color-paper)]', sizes[format]]}>
  {ADSENSE_CLIENT ? (
    <ins
      class="adsbygoogle block w-full"
      style="display:block"
      data-ad-client={ADSENSE_CLIENT}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
  ) : (
    label && <span class="text-xs text-[var(--color-muted)] font-mono">ad slot ({format})</span>
  )}
</aside>
