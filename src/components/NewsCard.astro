---
interface Props {
  href: string;
  title: string;
  summary: string;
  source: string;
  publishedAt: Date;
  image?: string;
  external?: boolean;
  relatedLinks?: Array<{
    label: string;
    href: string;
    live: boolean;
  }>;
}
const { href, title, summary, source, publishedAt, image, external = false, relatedLinks = [] } = Astro.props;
const dateStr = publishedAt.toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' });
const liveLinks = relatedLinks.filter((link) => link.live).slice(0, 3);
---
<article class="group rounded-xl border border-[var(--color-border)] bg-white hover:border-[var(--color-ink)] transition-colors overflow-hidden">
  {image && (
    <div class="aspect-[16/9] overflow-hidden bg-[var(--color-paper)]">
      <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
        <img src={image} alt="" loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />
      </a>
    </div>
  )}
  <div class="p-5">
    <div class="flex items-center gap-2 text-xs text-[var(--color-muted)] mb-2">
      <span class="font-medium text-[var(--color-accent)] uppercase tracking-wider">{source}</span>
      <span>&middot;</span>
      <time datetime={publishedAt.toISOString()}>{dateStr}</time>
      {external && <span class="ml-auto">&#8599;</span>}
    </div>
    <h3 class="text-lg font-semibold leading-snug text-[var(--color-ink)] transition-colors group-hover:text-[var(--color-accent)]">
      <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
        {title}
      </a>
    </h3>
    <p class="mt-2 text-sm text-[var(--color-ink-soft)] leading-relaxed line-clamp-3">
      <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
        {summary}
      </a>
    </p>
    {liveLinks.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {liveLinks.map((link) => (
          <a
            href={link.href}
            class="inline-flex items-center rounded-full border border-[var(--color-border)] bg-[var(--color-paper)] px-2.5 py-1 text-xs font-medium text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    )}
  </div>
</article>
