---
interface Props {
  variant?: 'hero' | 'inline' | 'sidebar';
  heading?: string;
  subheading?: string;
  source?: string;
}
const {
  variant = 'inline',
  heading = "Get BYD Canada updates before anyone else",
  subheading = "Launch dates, pre-order windows, price reveals, reviews. No spam, unsubscribe anytime.",
  source,
} = Astro.props;

const signupSource = source || variant;

const base = "rounded-2xl border border-[var(--color-border)]";
const styles = {
  hero: `${base} bg-[var(--color-ink)] text-[var(--color-paper)] p-8 md:p-10`,
  inline: `${base} bg-white p-6 md:p-8`,
  sidebar: `${base} bg-white p-5`,
};
const headingClass = variant === 'hero'
  ? 'text-2xl md:text-3xl font-semibold tracking-tight'
  : 'text-xl font-semibold tracking-tight text-[var(--color-ink)]';
const subClass = variant === 'hero'
  ? 'text-white/70 mt-2 text-sm md:text-base'
  : 'text-[var(--color-muted)] mt-1.5 text-sm';
const inputClass = variant === 'hero'
  ? 'flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-[var(--color-accent)]'
  : 'flex-1 px-4 py-3 rounded-lg bg-[var(--color-paper)] border border-[var(--color-border)] text-[var(--color-ink)] placeholder-[var(--color-muted)] focus:outline-none focus:border-[var(--color-accent)]';
---
<section class={styles[variant]}>
  <h3 class={headingClass}>{heading}</h3>
  <p class={subClass}>{subheading}</p>
  <form
    method="POST"
    action="/api/subscribe"
    class="mt-4 flex flex-col sm:flex-row gap-2"
    data-newsletter-form
  >
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="you@example.com"
      class={inputClass}
    />
    <input type="hidden" name="source" value={signupSource} />
    <button
      type="submit"
      class="px-5 py-3 rounded-lg bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-dark)] transition-colors"
    >
      Notify me
    </button>
  </form>
  <div data-newsletter-status class="mt-3 text-sm hidden"></div>
</section>

<script>
  document.querySelectorAll('[data-newsletter-form]').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    const status = form.parentElement?.querySelector('[data-newsletter-status]') as HTMLElement | null;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      if (status) {
        status.className = 'mt-3 text-sm text-[var(--color-muted)]';
        status.textContent = 'Signing up…';
        status.classList.remove('hidden');
      }
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          body: data,
        });
        if (res.ok) {
          if (status) {
            status.className = 'mt-3 text-sm text-green-700';
            status.textContent = "You're in. We'll email you when there's real news.";
          }
          form.reset();
        } else {
          const body = await res.json().catch(() => ({}));
          if (status) {
            status.className = 'mt-3 text-sm text-red-600';
            status.textContent = (body as { error?: string }).error || "Couldn't subscribe — try again.";
          }
        }
      } catch {
        if (status) {
          status.className = 'mt-3 text-sm text-red-600';
          status.textContent = "Network error. Try again.";
        }
      }
    });
  });
</script>
