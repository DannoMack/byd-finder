---
const { pathname } = Astro.url;
const isActive = (p: string) => pathname === p || pathname.startsWith(p + '/');

const links = [
  { href: '/ca/news', label: 'News' },
  { href: '/ca/dealers', label: 'Dealers' },
  { href: '/ca/models', label: 'Models' },
  { href: '/ca/comparisons', label: 'Comparisons' },
  { href: '/ca/faq', label: 'FAQ' },
  { href: '/ca/accessories', label: 'Accessories' },
];
---
<header class="border-b border-[var(--color-border)] bg-[var(--color-paper)]/95 backdrop-blur sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-4 md:px-6 h-14 flex items-center justify-between">
    <a href="/ca" class="flex items-center gap-2 group">
      <svg viewBox="-2015 -2000 4030 4030" class="w-5 h-5 fill-[var(--color-accent)]" aria-hidden="true">
        <path d="m-90 2030 45-863a95 95 0 0 0-111-98l-859 151 116-320a65 65 0 0 0-20-73l-941-762 212-99a65 65 0 0 0 34-79l-186-572 542 115a65 65 0 0 0 73-38l105-247 423 454a65 65 0 0 0 111-57l-204-1052 327 189a65 65 0 0 0 91-27l332-652 332 652a65 65 0 0 0 91 27l327-189-204 1052a65 65 0 0 0 111 57l423-454 105 247a65 65 0 0 0 73 38l542-115-186 572a65 65 0 0 0 34 79l212 99-941 762a65 65 0 0 0-20 73l116 320-859-151a95 95 0 0 0-111 98l45 863z"/>
      </svg>
      <span class="font-semibold tracking-tight text-[var(--color-ink)]">BYD Finder</span>
      <span class="text-xs text-[var(--color-muted)] hidden sm:inline">Canada</span>
    </a>
    <nav class="hidden md:flex items-center gap-1 md:gap-2">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'px-2 md:px-3 py-1.5 rounded-md text-sm font-medium transition-colors',
            isActive(l.href)
              ? 'bg-[var(--color-ink)] text-[var(--color-paper)]'
              : 'text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:bg-black/5',
          ]}
        >{l.label}</a>
      ))}
    </nav>
    <button
      type="button"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-[var(--color-ink)] hover:bg-black/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
    >
      <svg id="nav-icon-open" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <svg id="nav-icon-close" class="hidden w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
    </button>
  </div>
  <nav id="mobile-nav-panel" class="md:hidden hidden border-t border-[var(--color-border)] bg-[var(--color-paper)]">
    <div class="max-w-6xl mx-auto px-4 py-2 flex flex-col">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'px-3 py-2.5 rounded-md text-sm font-medium transition-colors',
            isActive(l.href)
              ? 'bg-[var(--color-ink)] text-[var(--color-paper)]'
              : 'text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:bg-black/5',
          ]}
        >{l.label}</a>
      ))}
    </div>
  </nav>
</header>
<script>
  const btn = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav-panel');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');
  if (btn && panel && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const open = panel.classList.toggle('hidden');
      const expanded = !open;
      btn.setAttribute('aria-expanded', String(expanded));
      btn.setAttribute('aria-label', expanded ? 'Close menu' : 'Open menu');
      iconOpen.classList.toggle('hidden', expanded);
      iconClose.classList.toggle('hidden', !expanded);
    });
  }
</script>
