---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — BYD Finder" description="Contact BYD Finder with tips, corrections, or partnership inquiries.">
  <article class="max-w-2xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--color-ink)]">Contact</h1>
    <p class="mt-4 text-lg text-[var(--color-ink-soft)]">
      Story tips, corrections, partnership inquiries &mdash; send us a note.
    </p>
    <div class="mt-8 rounded-xl border border-[var(--color-border)] bg-white p-6">
      <p class="text-[var(--color-ink-soft)]">
        Email: <a href="mailto:hello@bydfinder.com" class="text-[var(--color-accent)] hover:underline">hello@bydfinder.com</a>
      </p>
    </div>
  </article>
</BaseLayout>
