---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  const models = await getCollection('models');
  return models.map((m) => ({ params: { slug: m.data.slug }, props: { entry: m } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout
  title={`BYD ${entry.data.name} — Canada availability, specs, price`}
  description={`${entry.data.name}: specs, range, pricing, and Canadian availability. Track the ${entry.data.name}'s arrival in Canada.`}
>
  <article class="max-w-4xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="mb-6">
      <a href="/ca/models" class="text-sm text-[var(--color-accent)] hover:underline">&larr; All models</a>
    </div>

    <div class="flex items-start justify-between flex-wrap gap-4">
      <div>
        <div class="text-xs uppercase tracking-wider text-[var(--color-muted)] font-medium">{entry.data.bodyStyle}</div>
        <h1 class="mt-1 text-4xl md:text-5xl font-semibold tracking-tight leading-tight text-[var(--color-ink)]">
          BYD {entry.data.name}
        </h1>
      </div>
      <div class="text-xs font-semibold uppercase tracking-wider pt-2">
        {entry.data.availableInCanada ? (
          <span class="px-3 py-1.5 rounded-full bg-green-100 text-green-800">Available in Canada</span>
        ) : (
          <span class="px-3 py-1.5 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)]">Rumored for Canada</span>
        )}
      </div>
    </div>

    <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
      {entry.data.rangeKm && (
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-4">
          <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider">Range</div>
          <div class="mt-1 text-2xl font-semibold text-[var(--color-ink)]">{entry.data.rangeKm}<span class="text-sm font-normal text-[var(--color-muted)]"> km</span></div>
        </div>
      )}
      {entry.data.batteryKWh && (
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-4">
          <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider">Battery</div>
          <div class="mt-1 text-2xl font-semibold text-[var(--color-ink)]">{entry.data.batteryKWh}<span class="text-sm font-normal text-[var(--color-muted)]"> kWh</span></div>
        </div>
      )}
      {entry.data.priceFromCAD && (
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-4">
          <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider">Starting price</div>
          <div class="mt-1 text-2xl font-semibold text-[var(--color-ink)]">${entry.data.priceFromCAD.toLocaleString()}<span class="text-sm font-normal text-[var(--color-muted)]"> CAD</span></div>
        </div>
      )}
      {entry.data.driveTrain && (
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-4">
          <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider">Drivetrain</div>
          <div class="mt-1 text-lg font-semibold text-[var(--color-ink)]">{entry.data.driveTrain}</div>
        </div>
      )}
    </div>

    <div class="prose-article mt-10">
      <Content />
    </div>

    <div class="mt-12">
      <NewsletterSignup
        variant="inline"
        heading={`Get notified when the BYD ${entry.data.name} arrives in Canada`}
        subheading="Pre-order windows, pricing, dealer updates. One email when it matters."
      />
    </div>
  </article>
</BaseLayout>
