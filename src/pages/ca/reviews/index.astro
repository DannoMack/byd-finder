---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allReviews = (await getCollection('reviews'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---
<BaseLayout
  title="BYD Video Reviews — BYD Finder"
  description="Hand-picked video reviews of BYD EVs from trusted YouTube channels."
>
  <section class="max-w-6xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--color-ink)]">Reviews</h1>
      <p class="mt-2 text-[var(--color-muted)]">Curated test drives, walkarounds, and long-term ownership videos.</p>
    </div>

    {allReviews.length === 0 ? (
      <div class="rounded-xl border border-dashed border-[var(--color-border)] bg-white p-10 text-center">
        <p class="text-[var(--color-muted)]">Reviews coming soon.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allReviews.map((r) => (
          <a href={`/ca/reviews/${r.id}`} class="group block rounded-xl border border-[var(--color-border)] bg-white hover:border-[var(--color-ink)] transition-colors overflow-hidden">
            <div class="aspect-video bg-black">
              <img src={`https://i.ytimg.com/vi/${r.data.youtubeId}/hqdefault.jpg`} alt="" loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="p-5">
              <div class="text-xs text-[var(--color-muted)] uppercase tracking-wider font-medium">{r.data.channel} &middot; {r.data.model}</div>
              <h3 class="mt-1 text-lg font-semibold leading-snug text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">{r.data.title}</h3>
              <p class="mt-2 text-sm text-[var(--color-ink-soft)] leading-relaxed line-clamp-2">{r.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
