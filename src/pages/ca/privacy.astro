---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy — BYD Finder" description="Privacy policy for BYD Finder.">
  <article class="max-w-3xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--color-ink)]">Privacy</h1>
    <div class="prose-article mt-6">
      <p>
        BYD Finder collects email addresses submitted to our newsletter and
        basic analytics via Cloudflare Web Analytics (no cookies, no personal
        identifiers). We do not sell data. Unsubscribe at any time via the link
        in any email we send.
      </p>
      <p>
        Some outbound links are affiliate partnerships. We may earn a commission
        when you purchase through them; this does not affect the price you pay
        or our editorial choices.
      </p>
    </div>
  </article>
</BaseLayout>
