---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import RatehubWidget from '../../components/RatehubWidget.astro';

interface FAQItem {
  q: string;
  a: string;
  showRatehub?: boolean;
}
interface FAQSection {
  id: string;
  heading: string;
  items: FAQItem[];
}

// Answers drafted with stop-slop rules: active voice, specific numbers, no adverbs,
// no em-dashes, no throat-clearing openers. Update as real info lands.
const sections: FAQSection[] = [
  {
    id: 'arrival',
    heading: 'Arrival & launch',
    items: [
      {
        q: 'When will BYD arrive in Canada?',
        a: 'Toronto sees demo units by mid-2026. First retail sales land late 2026. Vancouver, Montreal, Calgary, and Ottawa follow in 2027.',
      },
      {
        q: 'Which Canadian cities get BYD first?',
        a: 'The Greater Toronto Area is launch city number one. BYD is scouting three GTA dealer sites right now. Phase two covers Vancouver, Montreal, and Calgary.',
      },
      {
        q: 'How many BYD dealerships will Canada get?',
        a: 'BYD wants 20 Canadian dealerships open within the first year.',
      },
      {
        q: 'Can I pre-order a BYD in Canada right now?',
        a: 'No. Pre-orders are not open. When BYD Canada opens reservations, we email everyone on our list the same day.',
      },
      {
        q: 'Is BYD definitely coming to Canada?',
        a: 'Yes. BYD registered its production facilities with Transport Canada\'s Appendix G preclearance registry (no other Chinese passenger-vehicle maker has). They hired Dealer Solutions Mergers & Acquisitions in Markham, Ontario, to scout retail locations.',
      },
    ],
  },
  {
    id: 'pricing',
    heading: 'Pricing (speculation)',
    items: [
      {
        q: 'What will a BYD cost in Canada?',
        a: 'BYD has not announced Canadian prices. Australia is the closest comparable: similar incomes, similar EV adoption, similar regulatory overhead. Australia\'s starting prices converted to CAD, plus a 10-25% Canadian launch premium, give us these estimates. Dolphin $32,000 to $36,000. Atto 3 $40,000 to $45,000. Seal $48,000 to $54,000. Sealion 7 $54,000 to $60,000. Base trims. Expect dealer markup on top in the first six months.',
      },
      {
        q: 'Why can BYD price so low?',
        a: 'BYD makes its own batteries (LFP Blade chemistry), owns most of its supply chain, and outsells every other EV maker by volume. Canada\'s 6.1% tariff on Chinese EVs still bites, but the 100% U.S. duty bites far harder.',
      },
      {
        q: 'Will the 6.1% tariff get passed to consumers?',
        a: 'Some of it. Manufacturers eat part of a tariff to stay priced against rivals and push the rest onto buyers. Expect Canadian BYDs to sit a bit above Australian prices (Australia charges about 5%) and well below what U.S. buyers would pay if imports weren\'t blocked. Canada also caps Chinese EV imports at 24,500 units per year at the reduced rate, which may tighten supply in year one.',
      },
    ],
  },
  {
    id: 'charging',
    heading: 'Charging in Canada',
    items: [
      {
        q: 'What charging connector do BYDs use?',
        a: 'North American BYDs should ship with the CCS1 connector. That works with most Canadian public DC fast chargers: Electrify Canada, Petro-Canada, Flo, BC Hydro. A J1772-to-NACS adapter opens up Tesla Superchargers where Tesla has opened its network to other brands.',
      },
      {
        q: 'Can I charge a BYD at home?',
        a: 'Yes. A Level 2 (240V, 32A) home charger from a licensed electrician fills most BYD packs overnight. Budget $500 to $1,200 for the hardware and $500 to $2,000 for installation, depending on your panel.',
      },
      {
        q: 'How much does it cost to charge an EV in Canada?',
        a: 'Home electricity in most provinces runs $0.08 to $0.15 per kWh. A full charge on a 60 kWh pack costs $5 to $9 at home. DC fast chargers charge $0.30 to $0.60 per kWh, so a full charge at Electrify Canada costs $18 to $36.',
      },
    ],
  },
  {
    id: 'winter',
    heading: 'Winter & cold weather',
    items: [
      {
        q: 'How will BYD EVs handle Canadian winters?',
        a: 'LFP (Blade Battery) chemistry loses more range in extreme cold than NMC does. It also holds up safer and lasts more cycles. Plan for 25% to 35% range loss at -20°C on a BYD you haven\'t preconditioned.',
      },
      {
        q: 'Can I rustproof or spray the undercarriage?',
        a: 'Yes, with caveats. Keep spray away from the battery pack, high-voltage connectors, and charging ports. Drip-style annual treatments from Krown or Rust Check work if the shop knows EVs. Skip heavy tar undercoating over battery enclosures.',
      },
      {
        q: 'Do I need winter tires for a BYD?',
        a: 'Yes. Quebec law requires them from December 1 to March 15. Everywhere else they are not required by law, but insurance companies often require them for full winter coverage. EVs are heavy. Good winter tires matter more on an EV than on a gas car.',
      },
      {
        q: 'Does BYD include a heat pump?',
        a: 'Atto 3, Seal, and Sealion 7 ship with heat pumps on most trims. Heat pumps beat resistive heating below 0°C and save you 10% to 25% of winter range. Canadian-market BYDs should all include them.',
      },
    ],
  },
  {
    id: 'service',
    heading: 'Service & repair',
    items: [
      {
        q: 'Where will I service a BYD in Canada?',
        a: 'At BYD-authorized dealerships. Each of the 20 planned year-one locations includes a service bay. Outside the GTA, expect long drives until more dealers open.',
      },
      {
        q: 'Will parts be available?',
        a: 'Routine service parts, yes. Body panels and collision-repair parts will take longer in the first 18 months because Canadian dealerships build inventory slowly and the supply chain from China adds lead time. BYD runs a large global parts operation, so oil changes and brake jobs are not the problem. Fender-benders are.',
      },
      {
        q: 'What warranty will BYD offer in Canada?',
        a: 'BYD has not confirmed Canadian warranty terms. Comparable markets get 6-year / 150,000 km on the vehicle and 8-year / 160,000 km on the battery.',
      },
    ],
  },
  {
    id: 'insurance',
    heading: 'Insurance & costs',
    items: [
      {
        q: 'Will insuring a BYD be expensive in Canada?',
        a: 'New nameplate, new data. Canadian insurers set premiums based on claims history and repair costs, and BYD has neither in Canada yet. Expect quotes in the first 12 months to land 10 to 25 percent above comparable Hyundai or Kia EVs while insurers calibrate. After two claim seasons the premium should normalize. Run a free comparison before buying so you know what you\'re walking into.',
        showRatehub: true,
      },
      {
        q: 'What will ownership cost per month?',
        a: 'Rough ballpark for a mid-trim Atto 3: $550 to $750 / month all-in at current rate estimates. That includes an 84-month finance payment on a $44,000 vehicle at 7% APR, $175/month insurance, $40/month home charging electricity, and $30/month for tires, wiper blades, and cabin filters. Your numbers vary by province and driving profile.',
      },
    ],
  },
  {
    id: 'company',
    heading: 'About BYD',
    items: [
      {
        q: 'Who is BYD?',
        a: 'BYD (Build Your Dreams) is a Chinese automaker founded in 1995. It has sold more EVs than any other company in the world since 2023. Warren Buffett\'s Berkshire Hathaway has been a shareholder since 2008. BYD also builds batteries, consumer electronics, and transit buses.',
      },
      {
        q: 'Is BYD safe?',
        a: 'Atto 3, Seal, and Sealion 7 all earned 5 stars from Euro NCAP and ANCAP. IIHS and NHTSA crash data for the Canadian market will come once vehicles are on North American roads.',
      },
      {
        q: 'Does BYD own Blade Battery technology?',
        a: 'Yes. The Blade Battery is BYD\'s own LFP pack design. LFP packs carry less energy per kilogram than NMC packs, survive more charge cycles, and resist thermal runaway better in a crash.',
      },
    ],
  },
];
---
<BaseLayout
  title="BYD Canada FAQ — arrival, prices, charging, winter"
  description="Everything Canadians are asking about BYD: when they're arriving, what they'll cost, how they handle winter, where to charge, and who services them."
>
  <section class="max-w-3xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--color-ink)]">FAQ</h1>
      <p class="mt-3 text-lg text-[var(--color-ink-soft)]">
        What Canadians are asking about BYD, answered with what we actually know.
      </p>
    </div>

    <!-- Section nav -->
    <nav class="mb-10 flex flex-wrap gap-2">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="px-3 py-1.5 rounded-full bg-white border border-[var(--color-border)] text-sm font-medium text-[var(--color-ink-soft)] hover:border-[var(--color-ink)] hover:text-[var(--color-ink)] transition-colors">
          {s.heading}
        </a>
      ))}
    </nav>

    {sections.map((section) => (
      <section id={section.id} class="mb-12 scroll-mt-20">
        <h2 class="text-xl font-semibold text-[var(--color-ink)] mb-4">{section.heading}</h2>
        <div class="space-y-3">
          {section.items.map((item) => (
            <>
              <details class="group rounded-xl border border-[var(--color-border)] bg-white p-5 [&[open]]:border-[var(--color-ink)]">
                <summary class="cursor-pointer font-semibold text-[var(--color-ink)] list-none flex items-start justify-between gap-4">
                  <span>{item.q}</span>
                  <span class="text-[var(--color-muted)] text-xl leading-none group-open:rotate-45 transition-transform">+</span>
                </summary>
                <p class="mt-3 text-[var(--color-ink-soft)] leading-relaxed">{item.a}</p>
              </details>
              {item.showRatehub && <RatehubWidget />}
            </>
          ))}
        </div>
      </section>
    ))}

    <div class="mt-12">
      <NewsletterSignup variant="inline" heading="Got a question we missed?" subheading="Email hello@bydfinder.com — and subscribe while you're here." />
    </div>
  </section>
</BaseLayout>
