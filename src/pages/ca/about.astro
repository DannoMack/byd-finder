---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="About — BYD Finder" description="About BYD Finder, an independent BYD Canada news site." noindex={true}>
  <article class="max-w-2xl mx-auto px-4 md:px-6 py-24 text-center">
    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--color-ink)]">About</h1>
    <p class="mt-6 text-lg text-[var(--color-muted)]">Under construction.</p>
    <p class="mt-3 text-sm text-[var(--color-muted)]">
      Real About page coming soon. In the meantime, BYD Finder is an independent
      Canadian enthusiast site. Not affiliated with BYD.
    </p>
    <a href="/ca" class="mt-8 inline-block px-5 py-3 rounded-lg bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-dark)] transition-colors">Back to home</a>
  </article>
</BaseLayout>
