---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';

const all = await getCollection('news');
const editorials = all
  .filter((i) => i.data.editorial)
  .sort((a, b) => a.id.localeCompare(b.id));
const scraped = all
  .filter((i) => !i.data.editorial)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Deterministic per-day rotation across editorials so all builds in the same UTC day agree.
const start = new Date(Date.UTC(new Date().getUTCFullYear(), 0, 0));
const dayOfYear = Math.floor((Date.now() - start.getTime()) / 86_400_000);
const featured = editorials.length > 0 ? editorials[dayOfYear % editorials.length] : null;
const restEditorials = featured ? editorials.filter((e) => e.id !== featured.id) : [];

// Interleave scraped items so the same source can't appear more than twice in a row.
// Otherwise Electrek's BYD-tagged feed dominates visually and the page reads single-sourced.
type ScrapedItem = (typeof scraped)[number];
function interleaveBySource(items: ScrapedItem[], maxRun = 2): ScrapedItem[] {
  const remaining = [...items];
  const out: ScrapedItem[] = [];
  let lastSource = '';
  let runLen = 0;
  while (remaining.length > 0) {
    let pickIdx = remaining.findIndex((i) =>
      i.data.source !== lastSource || runLen < maxRun,
    );
    if (pickIdx === -1) pickIdx = 0;
    const [picked] = remaining.splice(pickIdx, 1);
    if (picked.data.source === lastSource) {
      runLen += 1;
    } else {
      lastSource = picked.data.source;
      runLen = 1;
    }
    out.push(picked);
  }
  return out;
}
const interleaved = interleaveBySource(scraped, 2);
const feed = [...restEditorials, ...interleaved];
---
<BaseLayout
  title="BYD Canada News — BYD Finder"
  description="Latest news on BYD's Canadian market entry. Launch dates, model announcements, pricing, and regulatory updates."
>
  <section class="max-w-6xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--color-ink)]">News</h1>
      <p class="mt-2 text-[var(--color-muted)]">Aggregated BYD Canada coverage from trusted auto outlets, updated daily.</p>
    </div>

    {feed.length === 0 && !featured ? (
      <div class="rounded-xl border border-dashed border-[var(--color-border)] bg-white p-10 text-center">
        <p class="text-[var(--color-muted)]">No news yet &mdash; scraper runs nightly. Check back tomorrow.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured && (
          <NewsCard
            href={`/ca/news/${featured.id}`}
            title={featured.data.title}
            summary={featured.data.summary}
            source={featured.data.source}
            publishedAt={featured.data.publishedAt}
            image={featured.data.image}
            external={false}
            editorial={true}
            featured={true}
            relatedLinks={featured.data.internalLinks}
          />
        )}
        {feed.map((item) => (
          <NewsCard
            href={item.data.editorial ? `/ca/news/${item.id}` : item.data.sourceUrl}
            title={item.data.title}
            summary={item.data.summary}
            source={item.data.source}
            publishedAt={item.data.publishedAt}
            image={item.data.image}
            external={!item.data.editorial}
            editorial={item.data.editorial}
            relatedLinks={item.data.internalLinks}
          />
        ))}
      </div>
    )}

    <div class="mt-16">
      <NewsletterSignup variant="inline" />
    </div>
  </section>
</BaseLayout>
