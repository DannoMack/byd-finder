---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';
import RatehubWidget from '../../../components/RatehubWidget.astro';
import TcoCalculator from '../../../components/TcoCalculator.astro';
import {
  TCO_ASSUMPTIONS,
  calculateFiveYearTco,
  estimateWinterRangeKm,
  formatCurrency,
  type VehicleTcoInput,
} from '../../../utils/tco';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons');
  return comparisons.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const models = await getCollection('models');
const bydModel = models.find((model) => model.data.slug === entry.data.bydModelSlug);

if (!bydModel) {
  throw new Error(`Missing model content for comparison ${entry.data.slug}`);
}

const bydVehicle: VehicleTcoInput = {
  name: `BYD ${bydModel.data.name}`,
  slug: bydModel.data.slug,
  bodyStyle: bydModel.data.bodyStyle,
  priceFromCAD: bydModel.data.priceFromCAD || 0,
  rangeKm: bydModel.data.rangeKm || 0,
  batteryKWh: bydModel.data.batteryKWh || 0,
  driveTrain: bydModel.data.driveTrain || 'TBD',
  dcFastChargeKw: bydModel.data.dcFastChargeKw || 0,
  efficiencyKWhPer100Km: bydModel.data.efficiencyKWhPer100Km || 0,
  winterRangeLossPct: bydModel.data.winterRangeLossPct || 0,
  insurancePerYearCAD: bydModel.data.insurancePerYearCAD || 0,
  maintenancePerYearCAD: bydModel.data.maintenancePerYearCAD || 0,
  depreciationPct5yr: bydModel.data.depreciationPct5yr || 0,
};

const competitorVehicle: VehicleTcoInput = {
  ...entry.data.competitor,
};

const vehicles = [bydVehicle, competitorVehicle];
const provinceRows = Object.entries(TCO_ASSUMPTIONS.provinces).map(([slug, province]) => ({
  slug,
  province,
  byd: calculateFiveYearTco(bydVehicle, province),
  competitor: calculateFiveYearTco(competitorVehicle, province),
}));
const winterRows = vehicles.map((vehicle) => ({
  name: vehicle.name,
  rangeKm: vehicle.rangeKm,
  winterRangeKm: estimateWinterRangeKm(vehicle),
  lossPct: Math.round(vehicle.winterRangeLossPct * 100),
}));
---
<BaseLayout title={`${entry.data.title} — BYD Finder`} description={entry.data.summary}>
  <article class="max-w-6xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="mb-6">
      <a href="/ca/comparisons" class="text-sm text-[var(--color-accent)] hover:underline">&larr; All comparisons</a>
    </div>

    <section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_340px]">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]">Canada Comparison</div>
        <h1 class="mt-2 text-4xl md:text-6xl font-semibold tracking-tight leading-[1.02] text-[var(--color-ink)]">{entry.data.title}</h1>
        <p class="mt-4 max-w-3xl text-lg text-[var(--color-ink-soft)] leading-relaxed">{entry.data.summary}</p>
        <p class="mt-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-paper)] p-5 text-sm md:text-base leading-relaxed text-[var(--color-ink)]">
          <strong>Who this is for:</strong> {entry.data.targetBuyer}
        </p>
      </div>
      <div class="rounded-3xl border border-[var(--color-border)] bg-white p-6">
        <div class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">At a glance</div>
        <dl class="mt-4 space-y-4">
          <div>
            <dt class="text-sm text-[var(--color-ink-soft)]">BYD side</dt>
            <dd class="text-lg font-semibold text-[var(--color-ink)]">{bydVehicle.name}</dd>
          </div>
          <div>
            <dt class="text-sm text-[var(--color-ink-soft)]">Competitor</dt>
            <dd class="text-lg font-semibold text-[var(--color-ink)]">{competitorVehicle.name}</dd>
          </div>
          <div>
            <dt class="text-sm text-[var(--color-ink-soft)]">Default scenario</dt>
            <dd class="text-lg font-semibold text-[var(--color-ink)]">{TCO_ASSUMPTIONS.meta.years}-year TCO at {TCO_ASSUMPTIONS.meta.annualKmDefault.toLocaleString()} km/year</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="mt-12 rounded-3xl border border-[var(--color-border)] bg-white overflow-hidden">
      <div class="border-b border-[var(--color-border)] px-6 py-5">
        <h2 class="text-2xl font-semibold tracking-tight text-[var(--color-ink)]">Side-by-side specs</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-[var(--color-paper)] text-left">
            <tr>
              <th class="px-6 py-4 font-semibold text-[var(--color-muted)] uppercase tracking-wider">Spec</th>
              <th class="px-6 py-4 font-semibold text-[var(--color-ink)]">{bydVehicle.name}</th>
              <th class="px-6 py-4 font-semibold text-[var(--color-ink)]">{competitorVehicle.name}</th>
            </tr>
          </thead>
          <tbody>
            {entry.data.specRows.map((row, index) => (
              <tr class={index % 2 === 0 ? 'bg-white' : 'bg-[var(--color-paper)]/55'}>
                <td class="px-6 py-4 font-medium text-[var(--color-ink)]">{row.label}</td>
                <td class="px-6 py-4 text-[var(--color-ink-soft)]">{row.byd}</td>
                <td class="px-6 py-4 text-[var(--color-ink-soft)]">{row.competitor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 md:grid-cols-2">
      {winterRows.map((row) => (
        <div class="rounded-3xl border border-[var(--color-border)] bg-white p-6">
          <div class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)]">Winter range estimate</div>
          <h2 class="mt-2 text-2xl font-semibold text-[var(--color-ink)]">{row.name}</h2>
          <div class="mt-6 flex items-end justify-between gap-4">
            <div>
              <div class="text-sm text-[var(--color-ink-soft)]">Rated range</div>
              <div class="text-3xl font-semibold text-[var(--color-ink)]">{row.rangeKm} km</div>
            </div>
            <div class="text-right">
              <div class="text-sm text-[var(--color-ink-soft)]">January planning range</div>
              <div class="text-3xl font-semibold text-[var(--color-accent)]">{row.winterRangeKm} km</div>
            </div>
          </div>
          <p class="mt-4 text-sm text-[var(--color-ink-soft)]">Assumes roughly {row.lossPct}% winter loss once cabin heating, battery conditioning, and Canadian highway speeds are factored in.</p>
        </div>
      ))}
    </section>

    <section class="mt-12 rounded-3xl border border-[var(--color-border)] bg-white overflow-hidden">
      <div class="border-b border-[var(--color-border)] px-6 py-5">
        <h2 class="text-2xl font-semibold tracking-tight text-[var(--color-ink)]">5-year TCO by province</h2>
        <p class="mt-1 text-sm text-[var(--color-ink-soft)]">
          Default scenario uses {TCO_ASSUMPTIONS.meta.annualKmDefault.toLocaleString()} km/year and {Math.round(TCO_ASSUMPTIONS.meta.chargingLossPct * 100)}% charging loss.
        </p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-[var(--color-paper)] text-left">
            <tr>
              <th class="px-6 py-4 font-semibold uppercase tracking-wider text-[var(--color-muted)]">Province</th>
              <th class="px-6 py-4 font-semibold text-[var(--color-ink)]">{bydVehicle.name}</th>
              <th class="px-6 py-4 font-semibold text-[var(--color-ink)]">{competitorVehicle.name}</th>
              <th class="px-6 py-4 font-semibold uppercase tracking-wider text-[var(--color-muted)]">Electricity / gas</th>
            </tr>
          </thead>
          <tbody>
            {provinceRows.map((row, index) => (
              <tr class={index % 2 === 0 ? 'bg-white' : 'bg-[var(--color-paper)]/55'}>
                <td class="px-6 py-4">
                  <div class="font-semibold text-[var(--color-ink)]">{row.province.name}</div>
                </td>
                <td class="px-6 py-4">
                  <div class="font-semibold text-[var(--color-ink)]">{formatCurrency(row.byd.total)}</div>
                  <div class="mt-1 text-xs text-[var(--color-ink-soft)]">Depreciation {formatCurrency(row.byd.depreciation)} • charging {formatCurrency(row.byd.electricity)}</div>
                </td>
                <td class="px-6 py-4">
                  <div class="font-semibold text-[var(--color-ink)]">{formatCurrency(row.competitor.total)}</div>
                  <div class="mt-1 text-xs text-[var(--color-ink-soft)]">Depreciation {formatCurrency(row.competitor.depreciation)} • charging {formatCurrency(row.competitor.electricity)}</div>
                </td>
                <td class="px-6 py-4 text-[var(--color-ink-soft)]">{row.province.electricityCentsPerKWh}¢/kWh • ${row.province.gasPricePerLitre.toFixed(2)}/L</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="prose-article mt-12">
      <Content />
    </div>

    <section class="mt-12">
      <TcoCalculator
        id={`tco-${entry.data.slug}`}
        vehicles={vehicles}
        heading={`Interactive TCO: ${bydVehicle.name} vs ${competitorVehicle.name}`}
        subheading="Switch province and annual distance to see which car stays cheaper once Canadian utility bills and insurance multipliers start moving."
      />
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
      <div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-paper)] p-6 md:p-8">
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]">Next Step</div>
        <h2 class="mt-2 text-2xl md:text-3xl font-semibold tracking-tight text-[var(--color-ink)]">{entry.data.cta.heading}</h2>
        <p class="mt-3 text-[var(--color-ink-soft)] leading-relaxed">{entry.data.cta.body}</p>
        <div class="mt-8">
          <NewsletterSignup
            variant="inline"
            source={`comparison:${entry.data.slug}`}
            heading={`Track Canadian pricing for ${bydVehicle.name}`}
            subheading="We email when pricing, dealers, insurance quotes, or preorder timing becomes real."
          />
        </div>
      </div>
      <RatehubWidget
        heading="Check insurance before you pick the cheaper EV"
        subheading="Canadian EV premiums can erase a small MSRP advantage. Ratehub is the fastest sanity check."
        campaign={`comparison-${entry.data.slug}`}
      />
    </section>
  </article>
</BaseLayout>
