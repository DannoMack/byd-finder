---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Not found — BYD Finder" noindex={true}>
  <section class="max-w-2xl mx-auto px-4 md:px-6 py-24 text-center">
    <div class="text-6xl md:text-7xl font-semibold tracking-tight text-[var(--color-ink)]">404</div>
    <p class="mt-4 text-lg text-[var(--color-ink-soft)]">This page doesn't exist &mdash; or hasn't been written yet.</p>
    <a href="/ca" class="mt-6 inline-block px-5 py-3 rounded-lg bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-dark)] transition-colors">Back to home</a>
  </section>
</BaseLayout>
